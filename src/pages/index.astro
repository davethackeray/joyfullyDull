---
import Layout from '../layouts/Layout.astro';

// The "Live Now" state is driven client-side by fetching the Cloudflare Worker.
// The server-side default is always false.
const isLive = false;
const liveUrl = "https://youtube.com/@JoyfullyDull/live";
---

<Layout title="Joyfully Dull | Welcome to the slow lane.">

	<header class="flex justify-between items-center mb-16">
		<h1 class="font-typewriter text-3xl font-bold tracking-tighter">
			Joyfully Dull ☕️
		</h1>

		<!-- Live Now button — hidden by default, shown dynamically via JS -->
		<a
			id="live-btn"
			href={liveUrl}
			target="_blank"
			class="hidden bg-sunrise text-earlgrey font-typewriter font-bold px-4 py-2 rounded-full shadow-sm animate-pulse items-center gap-2 border border-earlgrey/20 transition hover:scale-105"
		>
			<span class="w-3 h-3 bg-red-500 rounded-full inline-block"></span>
			Dave is LIVE
		</a>
	</header>

	<!-- ── Manifesto ── -->
	<section class="mb-16 space-y-6 text-lg leading-relaxed">
		<h2 class="font-typewriter text-3xl font-bold mb-8">Welcome home.</h2>

		<div class="bg-white/40 p-8 rounded-2xl border border-earlgrey/10 shadow-sm space-y-6">
			<p>
				If you loved <span class="italic font-semibold">Mortimer & Whitehouse: Gone Fishing</span>, and you adored <span class="italic font-semibold">Great Canal Journeys</span>, and one of your great goals in life is to spend two hours lost in a book without reaching for your phone—welcome home.
			</p>

			<p>
				<span class="font-bold">Joyfully Dull</span> is where we revel in the magic of the tiniest things. We don't aspire to build skyscrapers. We don't want to name our first kid Instagram because that's all we can think about.
			</p>

			<p>
				We long to rediscover the art of being happily human. <br>
				Of enjoying every moment. <br>
				Of simply being.
			</p>

			<ul class="font-typewriter text-earlgrey/90 space-y-2 py-4 pl-4 border-l-2 border-denim/30">
				<li>☕️ Celebrating a sunrise.</li>
				<li>🍞 Toasting a well-baked loaf.</li>
				<li>🥾 Rejoicing in a walk on a crisp spring morning.</li>
			</ul>

			<p class="font-bold text-xl pt-2">
				The simple things. The good life.
			</p>

			<p>
				Join us as we raise a glass to being Joyfully Dull.
			</p>
		</div>
	</section>

	<hr class="border-earlgrey/20 mb-16" />

	<!-- ── The Weekly Rhythm ── -->
	<section class="mb-16">
		<h2 class="font-typewriter text-2xl font-semibold mb-6">The Weekly Rhythm</h2>

		<div class="grid md:grid-cols-2 gap-6">
			<div class="bg-white/40 rounded-2xl overflow-hidden border border-earlgrey/10 shadow-sm transition hover:shadow-md">
				<img src="/_assets/walkie-talkie.png" alt="Looking down at muddy hiking boots" class="w-full h-48 object-cover opacity-90 hover:opacity-100 transition" />
				<div class="p-6">
					<h3 class="font-typewriter font-bold text-xl">Walkie Talkie</h3>
					<p class="text-sm mt-1 font-semibold text-denim">Thursdays @ 10 AM CET</p>
					<p class="mt-2 text-earlgrey/80">Unedited, real-time walks around the Schwielowsee. Wind noise included.</p>
				</div>
			</div>

			<div class="bg-white/40 rounded-2xl overflow-hidden border border-earlgrey/10 shadow-sm transition hover:shadow-md">
				<img src="/_assets/breaditation.png" alt="Flour dusting over hands kneading dough" class="w-full h-48 object-cover opacity-90 hover:opacity-100 transition" />
				<div class="p-6">
					<h3 class="font-typewriter font-bold text-xl">Breaditation & Pizza Cake</h3>
					<p class="text-sm mt-1 font-semibold text-denim">Sundays @ 9 AM CET</p>
					<p class="mt-2 text-earlgrey/80">Let's take a soothing journey through the development of gluten strands as I prepare dough for some delicious bread. I'll even share the recipe.</p>
				</div>
			</div>

			<div class="bg-white/40 rounded-2xl overflow-hidden border border-earlgrey/10 shadow-sm transition hover:shadow-md md:col-span-2">
				<img src="/_assets/dave-book-club.png" alt="A public domain book under a warm reading lamp" class="w-full h-48 object-cover opacity-90 hover:opacity-100 transition" />
				<div class="p-6">
					<h3 class="font-typewriter font-bold text-xl">Dave's Book Club</h3>
					<p class="text-sm mt-1 font-semibold text-denim">Random Cozy Evenings</p>
					<p class="mt-2 text-earlgrey/80">Reading public domain classics until one of us falls asleep. Pure Hygge.</p>
				</div>
			</div>
		</div>

		<!-- ── Chat Convention ── -->
		<div class="mt-6 bg-white/40 border border-earlgrey/10 rounded-xl p-5 font-typewriter text-sm space-y-2">
			<p class="font-bold text-base">💬 Joining the conversation</p>
			<p class="text-earlgrey/80 leading-relaxed">During any live stream, feel free to chat with the community. If you'd like to talk <em>directly with Dave</em>, start your message with <span class="inline-block bg-sunrise text-earlgrey font-bold px-2 py-0.5 rounded text-xs tracking-wide">!ask</span> and he'll pick it up.</p>
		</div>
	</section>

	<!-- ── VIP Guestbook (Morning Pages) ── -->
	<section id="vip-section" class="bg-denim text-white rounded-2xl overflow-hidden shadow-sm flex flex-col md:flex-row">
		<img src="/_assets/morning-pages.png" alt="A pen resting on a journal with coffee in the background" class="w-full md:w-2/5 h-64 md:h-auto object-cover opacity-80 mix-blend-multiply" />

		<div class="p-8 md:w-3/5">
			<div class="inline-block bg-sunrise text-earlgrey text-xs font-bold px-3 py-1 rounded-full mb-4 font-typewriter">SUBSCRIBERS ONLY</div>
			<h2 class="font-typewriter text-2xl font-semibold mb-2">Morning Pages (Write Time)</h2>
			<p class="mb-6 opacity-90 text-sm">Join the free society. Get the private links to my unlisted journaling streams where we sort through the thoughts of the day.</p>

			<form id="vip-form" class="space-y-4">
				<div class="grid grid-cols-2 gap-4">
					<div>
						<input type="text" id="name" name="name" placeholder="First Name" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required>
					</div>
					<div>
						<input type="email" id="email" name="email" placeholder="Email Address" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required>
					</div>
				</div>
				<div>
					<textarea id="joy" name="joy" rows="2" placeholder="What is the most joyfully dull part of your day?" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required></textarea>
				</div>
				<button type="submit" class="bg-sunrise text-earlgrey font-typewriter font-bold px-6 py-3 rounded-md w-full transition hover:scale-[1.02] shadow-sm">
					Unlock the Morning Pages
				</button>
			</form>

			<!-- Success message (hidden by default) -->
			<div id="vip-success" class="hidden text-center py-8">
				<p class="font-typewriter text-xl font-bold mb-2">☕️ You're in.</p>
				<p class="text-sm opacity-90">Welcome to the quiet corner. Check your email for the Morning Pages link.</p>
			</div>

			<!-- Error message (hidden by default) -->
			<p id="vip-error" class="hidden text-sunrise font-typewriter text-sm mt-3 text-center"></p>
		</div>
	</section>

</Layout>

<script>

	document.addEventListener('DOMContentLoaded', () => {
		// ── "Live Now" check via Cloudflare Worker ──
		const LIVE_CHECK_URL = 'https://joyfully-dull-live-status.dave-c-thackeray.workers.dev';
		const liveBtn = document.getElementById('live-btn');

		async function checkLiveStatus() {
			try {
				const res = await fetch(LIVE_CHECK_URL);
				if (!res.ok) return;
				const data = await res.json();
				if (data.isLive && liveBtn) {
					liveBtn.classList.remove('hidden');
					liveBtn.classList.add('flex');
					if (data.videoId) {
						liveBtn.setAttribute('href', `https://www.youtube.com/watch?v=${data.videoId}`);
					}
				}
			} catch {
				// Silently fail — the button stays hidden
			}
		}
		checkLiveStatus();

		// ── VIP Form submission ──
		const form = document.getElementById('vip-form') as HTMLFormElement | null;
		const successMsg = document.getElementById('vip-success');
		const errorMsg = document.getElementById('vip-error');
		const VIP_SIGNUP_URL = 'https://joyfully-dull-vip-signup.dave-c-thackeray.workers.dev';

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const payload = {
				name: formData.get('name'),
				email: formData.get('email'),
				joy: formData.get('joy'),
			};

			try {
				const res = await fetch(VIP_SIGNUP_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				if (res.ok) {
					form.classList.add('hidden');
					successMsg?.classList.remove('hidden');
				} else {
					const data = await res.json().catch(() => ({}));
					if (errorMsg) {
						errorMsg.textContent = data.error || 'Something went wrong. Try again?';
						errorMsg.classList.remove('hidden');
					}
				}
			} catch {
				if (errorMsg) {
					errorMsg.textContent = 'Network error. Are you offline?';
					errorMsg.classList.remove('hidden');
				}
			}
		});
	});
</script>
