---
import Layout from '../layouts/Layout.astro';

// The "Live Now" state is driven client-side by fetching the Cloudflare Worker.
// The server-side default is always false.
const isLive = false;
const liveUrl = "https://youtube.com/@JoyfullyDull/live";
---

<Layout title="Joyfully Dull | Welcome to the slow lane.">

	<header class="flex justify-between items-center mb-16">
		<h1 class="font-typewriter text-3xl font-bold tracking-tighter">
			Joyfully Dull ☕️
		</h1>

		<!-- Live Now button — hidden by default, shown dynamically via JS -->
		<a
			id="live-btn"
			href={liveUrl}
			target="_blank"
			class="hidden bg-sunrise text-earlgrey font-typewriter font-bold px-4 py-2 rounded-full shadow-sm animate-pulse items-center gap-2 border border-earlgrey/20 transition hover:scale-105"
		>
			<span class="w-3 h-3 bg-red-500 rounded-full inline-block"></span>
			Dave is LIVE
		</a>
	</header>

	<!-- ── Dynamic Greeting ── -->
	<section class="mb-16 space-y-6 text-lg leading-relaxed">
		<h2 id="greeting" class="font-typewriter text-2xl font-semibold">Welcome to the digital porch.</h2>
		<p>
			I'm Dave. After 30 years chasing the next big thing as a broadcaster, I realized we've let the modern world engineer the fun right out of life. We are hypnotized by perfectly polished, artificial lives.
		</p>
		<p>
			But true Eudaimonia is found in the constant, purposeful struggle of being human. It's in the messy, the manual, and the painfully unexciting.
		</p>
		<p class="font-bold">
			This is a rebellion. Let's get back to the mellow stuff.
		</p>
	</section>

	<hr class="border-earlgrey/20 mb-16" />

	<!-- ── The Weekly Rhythm ── -->
	<section class="mb-16">
		<h2 class="font-typewriter text-2xl font-semibold mb-6">The Weekly Rhythm</h2>
		<div class="grid gap-4">
			<div class="bg-white/50 p-6 rounded-xl border border-earlgrey/10 transition hover:shadow-md hover:border-denim/30">
				<h3 class="font-typewriter font-bold text-xl">Simplicitea</h3>
				<p class="text-sm mt-1">Tuesdays @ 4 PM CET</p>
				<p class="mt-2 text-earlgrey/80">I drink a massive mug of tea, and we chat about the world. That's it.</p>
			</div>
			<div class="bg-white/50 p-6 rounded-xl border border-earlgrey/10 transition hover:shadow-md hover:border-denim/30">
				<h3 class="font-typewriter font-bold text-xl">Walkshopping</h3>
				<p class="text-sm mt-1">Thursdays @ 10 AM CET</p>
				<p class="mt-2 text-earlgrey/80">Unedited, real-time walks around the Schwielowsee. Wind noise included.</p>
			</div>
			<div class="bg-white/50 p-6 rounded-xl border border-earlgrey/10 transition hover:shadow-md hover:border-denim/30">
				<h3 class="font-typewriter font-bold text-xl">Breaditation & Pizza Cake</h3>
				<p class="text-sm mt-1">Sundays @ 9 AM CET</p>
				<p class="mt-2 text-earlgrey/80">Watch me knead dough and ride the temperature wave from bread to blistering pizza.</p>
			</div>
		</div>
	</section>

	<!-- ── VIP Guestbook (Morning Pages) ── -->
	<section id="vip-section" class="bg-denim text-white p-8 rounded-2xl shadow-sm">
		<h2 class="font-typewriter text-2xl font-semibold mb-2">The Morning Pages (VIP)</h2>
		<p class="mb-6 opacity-90 text-sm">Join the free society. Get access to my daily, unlisted journal livestreams where we forge diamonds in the dull.</p>

		<form id="vip-form" class="space-y-4">
			<div>
				<label for="name" class="block font-typewriter text-sm mb-1">First Name</label>
				<input type="text" id="name" name="name" class="w-full p-2 rounded-md text-earlgrey bg-sourdough border-none focus:ring-2 focus:ring-sunrise" required>
			</div>
			<div>
				<label for="email" class="block font-typewriter text-sm mb-1">Email</label>
				<input type="email" id="email" name="email" class="w-full p-2 rounded-md text-earlgrey bg-sourdough border-none focus:ring-2 focus:ring-sunrise" required>
			</div>
			<div>
				<label for="joy" class="block font-typewriter text-sm mb-1">What is the most joyfully dull part of your day?</label>
				<textarea id="joy" name="joy" rows="3" class="w-full p-2 rounded-md text-earlgrey bg-sourdough border-none focus:ring-2 focus:ring-sunrise" required></textarea>
			</div>
			<button type="submit" class="bg-sunrise text-earlgrey font-typewriter font-bold px-6 py-3 rounded-md w-full transition hover:brightness-95">
				Pull up a chair
			</button>
		</form>

		<!-- Success message (hidden by default) -->
		<div id="vip-success" class="hidden text-center py-8">
			<p class="font-typewriter text-xl font-bold mb-2">☕️ You're in.</p>
			<p class="text-sm opacity-90">Welcome to the quiet corner. Check your email for the Morning Pages link.</p>
		</div>

		<!-- Error message (hidden by default) -->
		<p id="vip-error" class="hidden text-sunrise font-typewriter text-sm mt-3 text-center"></p>
	</section>

</Layout>

<script>
	// ── Dynamic Greeting based on local time ──
	document.addEventListener('DOMContentLoaded', () => {
		const greeting = document.getElementById('greeting');
		if (greeting) {
			const hour = new Date().getHours();
			if (hour >= 5 && hour < 12) {
				greeting.textContent = 'Good morning. The kettle is on.';
			} else if (hour >= 12 && hour < 17) {
				greeting.textContent = 'Good afternoon. Pull up a chair.';
			} else {
				greeting.textContent = 'Good evening. Time to log off soon.';
			}
		}

		// ── "Live Now" check via Cloudflare Worker ──
		// Replace this URL with your deployed Worker URL
		const LIVE_CHECK_URL = '/api/live-status'; // proxied or direct Worker URL
		const liveBtn = document.getElementById('live-btn');

		async function checkLiveStatus() {
			try {
				const res = await fetch(LIVE_CHECK_URL);
				if (!res.ok) return;
				const data = await res.json();
				if (data.isLive && liveBtn) {
					liveBtn.classList.remove('hidden');
					liveBtn.classList.add('flex');
					if (data.videoId) {
						liveBtn.setAttribute('href', `https://www.youtube.com/watch?v=${data.videoId}`);
					}
				}
			} catch {
				// Silently fail — the button stays hidden
			}
		}
		checkLiveStatus();

		// ── VIP Form submission ──
		const form = document.getElementById('vip-form') as HTMLFormElement | null;
		const successMsg = document.getElementById('vip-success');
		const errorMsg = document.getElementById('vip-error');
		// Replace this URL with your deployed VIP signup Worker URL
		const VIP_SIGNUP_URL = '/api/vip-signup';

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const payload = {
				name: formData.get('name'),
				email: formData.get('email'),
				joy: formData.get('joy'),
			};

			try {
				const res = await fetch(VIP_SIGNUP_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				if (res.ok) {
					form.classList.add('hidden');
					successMsg?.classList.remove('hidden');
				} else {
					const data = await res.json().catch(() => ({}));
					if (errorMsg) {
						errorMsg.textContent = data.error || 'Something went wrong. Try again?';
						errorMsg.classList.remove('hidden');
					}
				}
			} catch {
				if (errorMsg) {
					errorMsg.textContent = 'Network error. Are you offline?';
					errorMsg.classList.remove('hidden');
				}
			}
		});
	});
</script>
