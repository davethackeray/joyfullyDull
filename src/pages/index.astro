---
import Layout from '../layouts/Layout.astro';

// The "Live Now" state is driven client-side by fetching the Cloudflare Worker.
// The server-side default is always false.
const isLive = false;
const liveUrl = "https://youtube.com/@JoyfullyDull/live";
---

<Layout title="Joyfully Dull | Welcome to the slow lane.">

	<header class="flex justify-between items-center mb-16">
		<h1 class="font-typewriter text-3xl font-bold tracking-tighter">
			Joyfully Dull ☕️
		</h1>

		<a
			id="live-btn"
			href={liveUrl}
			target="_blank"
			class="hidden bg-sunrise text-earlgrey font-typewriter font-bold px-4 py-2 rounded-full shadow-sm animate-pulse items-center gap-2 border border-earlgrey/20 transition hover:scale-105"
		>
			<span class="w-3 h-3 bg-red-500 rounded-full inline-block"></span>
			Dave is LIVE
		</a>
	</header>

	<section class="mb-16 space-y-6 text-lg leading-relaxed">
		<h2 class="font-typewriter text-4xl font-bold mb-8">The Internet is Too Loud. Let's Make Toast.</h2>

		<div class="bg-white/40 p-8 rounded-2xl border border-earlgrey/10 shadow-sm space-y-6">
			<p>
				Humanity is hurtling towards the technological singularity on a bullet train powered by outrage algorithms and optimised dopamine. And to be perfectly honest, we couldn't give a fuck.
			</p>
			<p>
				The modern world wants you to "crush it." We want you to sit down. You are a fragile, water-based biological creature, not a productivity app. We're all going to die someday anyway, so you might as well spend 13 minutes watching a bloke argue with the unearned confidence of a thermos flask.
			</p>
			<p>
				Welcome to the slow lane. Welcome to <span class="font-bold">Joyfully Dull</span>.
			</p>
			<p>
				We have proudly lowered the bar to the floor. This is a sanctuary of profound mediocrity and low-stakes dilemmas. We don't do life hacks, hustle culture, or 10-step morning routines. We do 60% hydration doughs, terrible knife skills, pram walks on German gravel, and serious pub debates about whether a Hobnob could win a physical fight.
			</p>
			<p>
				It’s not going to change your life. In fact, if you learn absolutely anything while you're here, we sincerely apologise.
			</p>
			<p class="font-typewriter font-bold text-xl pt-4">
				Grab a cuppa. Empty your brain. The water roux is cooling.
			</p>
		</div>
	</section>

	<hr class="border-earlgrey/20 mb-16" />

	<section class="mb-16">
		<h2 class="font-typewriter text-2xl font-semibold mb-6">Listen in the Slow Lane</h2>
		
		<div class="bg-white/40 p-2 rounded-2xl border border-earlgrey/10 shadow-sm">
			<iframe 
				style="border-radius:12px" 
				src="https://open.spotify.com/embed/show/1GUyaT8BEIFjVGBf2kCmGU?utm_source=generator&theme=0" 
				width="100%" 
				height="352" 
				frameBorder="0" 
				allowfullscreen="" 
				allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
				loading="lazy">
			</iframe>
		</div>
	</section>

	<hr class="border-earlgrey/20 mb-16" />

	<section class="mb-16">
		<h2 class="font-typewriter text-2xl font-semibold mb-6">The Weekly Rhythm</h2>

		<div class="grid md:grid-cols-2 gap-6">
			<div class="bg-[#e6d5c3]/30 rounded-2xl overflow-hidden border border-[#e6d5c3] shadow-sm transition hover:shadow-md flex flex-col">
				<div class="p-6 flex-grow flex flex-col justify-between">
					<div>
						<h3 class="font-typewriter font-bold text-xl">Simplicitea</h3>
						<p class="text-sm mt-1 font-semibold text-earlgrey">Sundays</p>
						<p class="mt-2 text-earlgrey/80 text-sm">Sunday rambles, broken legs, and terrible tech setups. A proper brew and a chat.</p>
					</div>
				</div>
			</div>

			<div class="bg-[#c89b3c]/20 rounded-2xl overflow-hidden border border-[#c89b3c]/40 shadow-sm transition hover:shadow-md flex flex-col">
				<div class="p-6 flex-grow flex flex-col justify-between">
					<div>
						<h3 class="font-typewriter font-bold text-xl">Breaditation</h3>
						<p class="text-sm mt-1 font-semibold text-earlgrey">Sundays @ 9 AM CET</p>
						<p class="mt-2 text-earlgrey/80 text-sm">Therapy via gluten. Watch me knead dough, drop things, and ride the temperature wave to a blistered pizza.</p>
					</div>
				</div>
			</div>

			<div class="bg-[#8fa98f]/20 rounded-2xl overflow-hidden border border-[#8fa98f]/40 shadow-sm transition hover:shadow-md flex flex-col">
				<div class="p-6 flex-grow flex flex-col justify-between">
					<div>
						<h3 class="font-typewriter font-bold text-xl">Baby steps</h3>
						<p class="text-sm mt-1 font-semibold text-earlgrey">Thursdays @ 10 AM CET</p>
						<p class="mt-2 text-earlgrey/80 text-sm">Unedited, real-time pram walks around the Schwielowsee. Wind noise and gravel crunching included.</p>
					</div>
				</div>
			</div>

			<div class="bg-[#bc6c4b]/20 rounded-2xl overflow-hidden border border-[#bc6c4b]/40 shadow-sm transition hover:shadow-md flex flex-col">
				<div class="p-6 flex-grow flex flex-col justify-between">
					<div>
						<h3 class="font-typewriter font-bold text-xl">Book club</h3>
						<p class="text-sm mt-1 font-semibold text-earlgrey">Random Cozy Evenings</p>
						<p class="mt-2 text-earlgrey/80 text-sm">Reading public domain classics until one of us falls asleep. Pure, unadulterated hygge.</p>
					</div>
				</div>
			</div>
		</div>

		<div class="mt-6 bg-white/40 border border-earlgrey/10 rounded-xl p-5 font-typewriter text-sm space-y-2">
			<p class="font-bold text-base">💬 The Voice in My Ear</p>
			<p class="text-earlgrey/80 leading-relaxed">During any live stream, feel free to chat with the community. If you'd like the AI Producer to whisper your question directly into my ear while I'm walking or baking, start your message with <span class="inline-block bg-sunrise text-earlgrey font-bold px-2 py-0.5 rounded text-xs tracking-wide">!ask</span>.</p>
		</div>
	</section>

	<section id="vip-section" class="bg-denim text-white rounded-2xl overflow-hidden shadow-sm flex flex-col md:flex-row">
		<img src="/images/morning-pages.png" alt="A pen resting on a journal with coffee in the background" class="w-full md:w-2/5 h-64 md:h-auto object-cover opacity-80 mix-blend-multiply" />

		<div class="p-8 md:w-3/5">
			<div class="inline-block bg-sunrise text-earlgrey text-xs font-bold px-3 py-1 rounded-full mb-4 font-typewriter">SUBSCRIBERS ONLY</div>
			<h2 class="font-typewriter text-2xl font-semibold mb-2">Morning Pages (Write Time)</h2>
			<p class="mb-6 opacity-90 text-sm">Join the free society. Get the private links to my unlisted journaling streams where we sort through the thoughts of the day.</p>

			<form id="vip-form" class="space-y-4">
				<div class="grid grid-cols-2 gap-4">
					<div>
						<input type="text" id="name" name="name" placeholder="First Name" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required>
					</div>
					<div>
						<input type="email" id="email" name="email" placeholder="Email Address" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required>
					</div>
				</div>
				<div>
					<textarea id="joy" name="joy" rows="2" placeholder="What is the most joyfully dull part of your day?" class="w-full p-3 rounded-md text-earlgrey bg-sourdough/90 border-none focus:ring-2 focus:ring-sunrise placeholder-earlgrey/50" required></textarea>
				</div>
				<button type="submit" class="bg-sunrise text-earlgrey font-typewriter font-bold px-6 py-3 rounded-md w-full transition hover:scale-[1.02] shadow-sm">
					Unlock the Morning Pages
				</button>
			</form>

			<div id="vip-success" class="hidden text-center py-8">
				<p class="font-typewriter text-xl font-bold mb-2">☕️ You're in.</p>
				<p class="text-sm opacity-90">Welcome to the quiet corner. Check your email for the Morning Pages link.</p>
			</div>

			<p id="vip-error" class="hidden text-sunrise font-typewriter text-sm mt-3 text-center"></p>
		</div>
	</section>

</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		// ── "Live Now" check via Cloudflare Worker ──
		const LIVE_CHECK_URL = 'https://joyfully-dull-live-status.dave-c-thackeray.workers.dev';
		const liveBtn = document.getElementById('live-btn');

		async function checkLiveStatus() {
			try {
				const res = await fetch(LIVE_CHECK_URL);
				if (!res.ok) return;
				const data = await res.json();
				if (data.isLive && liveBtn) {
					liveBtn.classList.remove('hidden');
					liveBtn.classList.add('flex');
					if (data.videoUrl) {
						liveBtn.setAttribute('href', data.videoUrl);
					}
				}
			} catch {
				// Silently fail
			}
		}
		checkLiveStatus();

		// ── VIP Form submission ──
		const form = document.getElementById('vip-form') as HTMLFormElement | null;
		const successMsg = document.getElementById('vip-success');
		const errorMsg = document.getElementById('vip-error');
		const VIP_SIGNUP_URL = 'https://joyfully-dull-vip-signup.dave-c-thackeray.workers.dev';

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const formData = new FormData(form);
			const payload = {
				name: formData.get('name'),
				email: formData.get('email'),
				joy: formData.get('joy'),
			};

			try {
				const res = await fetch(VIP_SIGNUP_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				if (res.ok) {
					form.classList.add('hidden');
					successMsg?.classList.remove('hidden');
				} else {
					const data = await res.json().catch(() => ({}));
					if (errorMsg) {
						errorMsg.textContent = data.error || 'Something went wrong. Try again?';
						errorMsg.classList.remove('hidden');
					}
				}
			} catch {
				if (errorMsg) {
					errorMsg.textContent = 'Network error. Are you offline?';
					errorMsg.classList.remove('hidden');
				}
			}
		});
	});
</script>