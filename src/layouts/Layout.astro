---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="A digital sanctuary for the constant purposeful struggle of being human." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="theme-color" content="#f4ebd8" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<title>{title}</title>
	</head>
	<body class="bg-sourdough text-earlgrey font-book antialiased min-h-screen flex flex-col items-center p-6 md:p-12">

		<!-- ── "Take a Breath" Preloader ── -->
		<div id="preloader" class="fixed inset-0 z-50 bg-sourdough flex items-center justify-center transition-opacity duration-700">
			<p class="font-typewriter text-lg md:text-xl text-center max-w-md px-6 leading-relaxed opacity-0 animate-fade-in">
				Take a deep breath.<br/>You are safe from the algorithm here.
			</p>
		</div>

		<main class="max-w-3xl w-full">
			<slot />
		</main>

		<footer class="mt-20 text-center text-sm font-typewriter opacity-70 pb-10 space-y-3">
			<p>No algorithms. No hustle. Just human.</p>
			<p>&copy; 2026 Joyfully Dull.</p>

			<!-- ── Analog Toggle ── -->
			<div class="flex items-center justify-center gap-3 mt-4">
				<span class="text-xs">Analog Mode</span>
				<button
					id="analog-toggle"
					aria-label="Toggle ambient Schwielowsee sounds"
					class="relative w-12 h-6 bg-earlgrey/20 rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-sunrise"
				>
					<span id="analog-knob" class="absolute top-0.5 left-0.5 w-5 h-5 bg-denim rounded-full transition-transform duration-300"></span>
				</button>
			</div>
			<audio id="ambient-audio" loop preload="none">
				<source src="/audio/schwielowsee.mp3" type="audio/mpeg" />
			</audio>
		</footer>
	</body>
</html>

<style is:global>
	/* Preloader fade-in text */
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(8px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in {
		animation: fadeIn 0.8s ease-out 0.3s forwards;
	}

	/* Smooth page reveal */
	html {
		scroll-behavior: smooth;
	}

	/* Subtle selection colors */
	::selection {
		background-color: #fcecb4;
		color: #2b2b2b;
	}
</style>

<script>
	// ── Preloader: hold for 1.5s then fade out ──
	document.addEventListener('DOMContentLoaded', () => {
		const preloader = document.getElementById('preloader');
		if (preloader) {
			setTimeout(() => {
				preloader.style.opacity = '0';
				setTimeout(() => preloader.remove(), 700);
			}, 1500);
		}

		// ── Analog Toggle — Web Audio pink noise generator ──
	const toggle = document.getElementById('analog-toggle');
	const knob = document.getElementById('analog-knob');
	let isPlaying = false;
	let audioCtx: AudioContext | null = null;
	let noiseSource: AudioBufferSourceNode | null = null;
	let gainNode: GainNode | null = null;

	function buildPinkNoise(ctx: AudioContext): AudioBuffer {
		const bufferSize = 2 * ctx.sampleRate;
		const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
		const data = buffer.getChannelData(0);
		let b0 = 0, b1 = 0, b2 = 0, b3 = 0, b4 = 0, b5 = 0, b6 = 0;
		for (let i = 0; i < bufferSize; i++) {
			const w = Math.random() * 2 - 1;
			b0 = 0.99886 * b0 + w * 0.0555179;
			b1 = 0.99332 * b1 + w * 0.0750759;
			b2 = 0.96900 * b2 + w * 0.1538520;
			b3 = 0.86650 * b3 + w * 0.3104856;
			b4 = 0.55000 * b4 + w * 0.5329522;
			b5 = -0.7616 * b5 - w * 0.0168980;
			data[i] = (b0 + b1 + b2 + b3 + b4 + b5 + b6 + w * 0.5362) * 0.11;
			b6 = w * 0.115926;
		}
		return buffer;
	}

	function startNoise() {
		audioCtx = new AudioContext();
		gainNode = audioCtx.createGain();
		gainNode.gain.setValueAtTime(0, audioCtx.currentTime);
		gainNode.gain.linearRampToValueAtTime(0.18, audioCtx.currentTime + 1.5);
		noiseSource = audioCtx.createBufferSource();
		noiseSource.buffer = buildPinkNoise(audioCtx);
		noiseSource.loop = true;
		noiseSource.connect(gainNode);
		gainNode.connect(audioCtx.destination);
		noiseSource.start();
	}

	function stopNoise() {
		if (gainNode && audioCtx) {
			gainNode.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.8);
		}
		setTimeout(() => {
			noiseSource?.stop();
			audioCtx?.close();
			noiseSource = null;
			audioCtx = null;
			gainNode = null;
		}, 900);
	}

	toggle?.addEventListener('click', () => {
		isPlaying = !isPlaying;
		if (knob) knob.style.transform = isPlaying ? 'translateX(1.5rem)' : 'translateX(0)';
		if (toggle) (toggle as HTMLElement).style.backgroundColor = isPlaying ? '#6b8caf' : '';
		isPlaying ? startNoise() : stopNoise();
	});
	});
</script>
